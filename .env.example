# chicos, hagan esto para desplegar:
#   1. git clone https://github.com/mletelle/GPIV-Gestion-Parque-Industrial-Viedma
#   1.1 fijense la rama
#   2. cd GPIV-Gestion-Parque-Industrial-Viedma
#   3. cp .env.example .env
#   4. abran el .env que crearon y cambien la clave de la base datos
#   5. docker compose up --build
#   6. despues cada vez que quieran levantar la app, solo hagan docker compose up
#
# la app queda en http://localhost:8000
#
# el .env no se sube al repo porque tiene claves, por eso existe este archivo de ejemplo
# las credenciales reales me las piden por whatsapp

# django
SECRET_KEY=django-insecure-cambiar-en-produccion-esta-clave-es-solo-para-dev
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# bd
# cambien "cambiar_esto" por cualquier clave, es solo local. con 12345 funciona igual.
POSTGRES_DB=gpiv_db
POSTGRES_USER=gpiv_user
POSTGRES_PASSWORD=cambiar_esto
DB_HOST=db
DB_PORT=5432

# para cuando subamos a produccion despues
# CSRF_TRUSTED_ORIGINS=https://gpiv.tivena.com.ar

# correo saliente. por defecto usa el backend de consola (imprime el mail en
# stdout) porque no tenemos cuenta smtp paga. para produccion real con smtp,
# descomentar y completar:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.proveedor.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@gpiv.local

# bandeja interna que recibe avisos de tickets nuevos (consultas de la landing
# y mensajes de usuarios logueados). si no se setea, cae en DEFAULT_FROM_EMAIL.
# SUPPORT_INBOX_EMAIL=fakeenrepavi@gmail.com

# resend.com (envio transaccional). dejar vacio en dev: los emails se loguean
# como warning y no se envian. ver https://resend.com/docs
# RESEND_API_KEY=

# url base del sitio para los links en emails. sin barra final.
# en dev queda en localhost, en produccion setear al dominio real.
# SITE_URL=https://gpiv.tivena.com.ar
